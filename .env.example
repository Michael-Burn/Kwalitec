# Kwalitec Environment Configuration
# Copy this file to .env and fill in your values.

# Application environment: development or production
FLASK_APP=run.py
FLASK_ENV=development
APP_ENV=development

# Secret key for session signing and CSRF protection.
# Generate a strong random key for production use:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key

# Database URL (optional — SQLite is used when not set)
# For PostgreSQL: postgresql+psycopg://user:password@host:5432/kwalitec
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/kwalitec

# Administrator credentials (production only — used by StartupService
# on first application startup to create the initial admin user).
# In development, use the CLI: flask --app run.py create-admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me