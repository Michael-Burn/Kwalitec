# Kwalitec Environment Configuration
# Copy this file to .env and fill in your values.

# Application environment: development or production
FLASK_APP=run.py
FLASK_ENV=development
APP_ENV=development

# Secret key for session signing and CSRF protection.
# Generate a strong random key for production use:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key

# Database URL (optional — SQLite is used when not set)
# For PostgreSQL: postgresql+psycopg://user:password@host:5432/kwalitec
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/kwalitec

# Administrator credentials — used by the create-admin CLI and StartupService.
# Fill these in before running flask --app run.py create-admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Legacy Founder bootstrap allowlist (comma-separated). Prefer durable RBAC roles
# (user_roles / user_capabilities). Matching emails still grant Console access and
# sync the Founder role on first authorised access (PR-001 transition bridge).
# FOUNDER_EMAILS=founder@example.com

# Production reverse-proxy / HTTPS (Render terminates TLS).
# TRUSTED_PROXY_HOPS=1
# PREFERRED_URL_SCHEME=https

# PostgreSQL pool tuning (ignored for SQLite).
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800

# Observability thresholds.
# SLOW_REQUEST_THRESHOLD_MS=1000
# HEALTH_ALERT_DB_LATENCY_MS=500
# PROFILE_SQL=0
# SESSION_LIFETIME_HOURS=12

# Educational Intelligence Internal Alpha (developer daily use only — not public).
# When set, enables the EI Recommendation card on the dashboard (orchestrator +
# recommendations only). Missions / explainability / progress stay off.
# Requires an active study plan with a curriculum attached.
# KWALITEC_EI_INTERNAL_ALPHA=1

# Version 2 dual-run / cutover (ADR-007). Safe defaults keep V1 as primary home.
# KWALITEC_V2_STUDENT_EXPERIENCE=1   # Show /student entry from dashboard
# KWALITEC_V2_DURABLE_STORE=1        # Persist Experience/Session via SQLAlchemy
# KWALITEC_V2_INJECT_ENGINES=1       # Wire opaque Phase I engine bridges
# KWALITEC_V2_SEED_DEMO=0            # Disable demo seed when durable (recommended)
# KWALITEC_V2_FOUNDER_INTELLIGENCE=1 # Enable Founder Intelligence signals
# KWALITEC_V2_SOLE_RUNTIME=1         # ONLY after evidence gates — / → /student

# Internal Alpha operational metadata (ALPHA-001) — presentation / support only.
# KWALITEC_BUILD_NUMBER=local
# KWALITEC_BUILD_DATE=2026-07-23
# KWALITEC_GIT_COMMIT=
# KWALITEC_SUPPORT_CONTACT=alpha-support@kwalitec.com

# Educational Operating System (src/) — APP-004 production readiness
# APP_VERSION=2.0.0
# LOG_LEVEL=INFO
# STRUCTURED_LOGGING=1
# EOS_DATABASE_URL=postgresql+psycopg://user:password@host:5432/kwalitec
#
# AI enrichment is optional presentation-only (ADR-008). Disable for deterministic-only runs.
# AI_PROVIDER=openai          # openai | anthropic | gemini | none
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=                 # or OPENAI_API_KEY / ANTHROPIC_API_KEY / GEMINI_API_KEY
# AI_TIMEOUT_SECONDS=15
# AI_MAX_RETRIES=2
# AI_RETRY_BACKOFF_SECONDS=0.25
# AI_ENRICHMENT_DISABLED=0
